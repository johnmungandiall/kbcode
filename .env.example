# Copy this file to ".env" and fill in the key for the provider you want.

# --- Pick a provider (default: anthropic) -----------------------------
# KBCODE_PROVIDER=anthropic   # anthropic | openai | gemini | deepseek | openrouter | mimo | ollama | custom
# KBCODE_MODEL=               # optional: override the model id for that provider

# --- API keys (only the one for your chosen provider is needed) -------
ANTHROPIC_API_KEY=sk-ant-...          # for anthropic (Claude)
# OPENAI_API_KEY=sk-...               # for openai (ChatGPT models)
# GEMINI_API_KEY=...                  # for gemini (Google)
# DEEPSEEK_API_KEY=...                # for deepseek
# OPENROUTER_API_KEY=sk-or-...        # for openrouter and mimo (many models, one key)
# OLLAMA_API_KEY=                     # for ollama; leave unset for a local server, no key needed

# --- Custom / self-hosted OpenAI-compatible endpoint ------------------
# KBCODE_PROVIDER=custom
# KBCODE_BASE_URL=https://your-endpoint/v1
# KBCODE_API_KEY=...
# KBCODE_MODEL=your-model-id

# --- Optional tuning --------------------------------------------------
# KBCODE_EFFORT=high          # Claude only: low | medium | high | max
# KBCODE_MAX_TOKENS=16000
# KBCODE_COMPACT_TOKENS=12000 # auto-summarize the chat past this size (0 = off)
# KBCODE_REQUEST_TIMEOUT=120  # per-request timeout in seconds; a stalled model then
#                             # fails fast and retries instead of freezing for ~10 min
#                             # (the SDK default). 0 = restore the SDK default (no timeout)
# KBCODE_MAX_STEPS=50         # tool round-trips allowed per user message before the agent
#                             # pauses with "hit the step limit" (say "continue" to resume).
#                             # Raise it for long unattended tasks; it exists to stop runaway loops.
# KBCODE_MAX_COMMANDS=25      # run_command calls allowed per turn (same runaway-loop guard)
# KBCODE_LOG_LEVEL=INFO       # quiet on-disk trace at ~/.kbcode/projects/<slug>/kbcode.log
#                             # for debugging; DEBUG = full detail, off/none = no file
# KBCODE_HOME=                # relocate ~/.kbcode itself (global settings, model cache,
#                             # and every project's runtime state under projects/)
# KBCODE_REDACT_SECRETS=false # off by default is NOT recommended; on by default

# --- Auxiliary vision fallback (images + /video) -----------------------
# Used automatically when your main model can't accept an image directly
# (falls back to describing it with another model instead of failing), and
# always for /video (none of kbcode's providers accept video natively).
# Auto-detected from whichever of these is already set, in order:
#   1. KBCODE_VISION_API_KEY below (explicit override, always trusted)
#   2. your main provider's own key, but only if it's genuinely OpenRouter
#      (i.e. its base_url really is openrouter.ai — a preset like "mimo"
#      pointed at a custom KBCODE_BASE_URL does NOT count, even though its
#      key happens to live in OPENROUTER_API_KEY)
#   3. ANTHROPIC_API_KEY, then GEMINI_API_KEY, then OPENAI_API_KEY above
# So most setups with any one of those already need nothing extra here.
# Note: an Anthropic-resolved fallback can describe images but not video
# (Claude's API has no video content-part) — set one of the others for /video.
# KBCODE_VISION_API_KEY=       # explicit override, tried first
# KBCODE_VISION_KIND=openai    # "openai" (default) or "anthropic", for the override above
# KBCODE_VISION_BASE_URL=      # defaults to https://openrouter.ai/api/v1
# KBCODE_VISION_MODEL=         # defaults to google/gemini-2.0-flash-001

# Default models per provider:
#   anthropic  -> claude-opus-4-8
#   openai     -> gpt-4o
#   gemini     -> gemini-2.0-flash
#   deepseek   -> deepseek-chat
#   openrouter -> openai/gpt-4o   (set KBCODE_MODEL for any other, e.g. deepseek/deepseek-chat)
#   mimo       -> via OpenRouter  (set KBCODE_MODEL to the exact MiMo id you want)
#   ollama     -> llama3.1        (local server at http://localhost:11434/v1 by default)
